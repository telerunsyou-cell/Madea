require('dotenv').config();
const { REST, Routes, SlashCommandBuilder } = require('discord.js');

// ✅ pull from Railway env
const { TOKEN, CLIENT_ID, GUILD_ID } = process.env;

// ✅ validate early (prevents confusing crashes)
if (!TOKEN || !CLIENT_ID || !GUILD_ID) {
  console.error("Missing TOKEN, CLIENT_ID, or GUILD_ID in environment variables");
  process.exit(1);
}

const commands = [
  new SlashCommandBuilder()
    .setName('flood')
    .setDescription('Send messages with Willy')
    .addStringOption(o =>
      o.setName('message')
        .setDescription('Message to send')
        .setRequired(true)
    )
    .addIntegerOption(o =>
      o.setName('count')
        .setDescription('Number of times to send (1-16)')
        .setMinValue(1)   // ✅ restore limits
        .setMaxValue(16)
    ),

  new SlashCommandBuilder()
    .setName('earthrock')
    .setDescription('We Active'),

].map(cmd => cmd.toJSON());

const rest = new REST({ version: '10' }).setToken(TOKEN);

(async () => {
  try {
    console.log("Registering commands...");

    await rest.put(
      Routes.applicationGuildCommands(CLIENT_ID, GUILD_ID),
      { body: commands }
    );

    console.log("Commands registered successfully!");
  } catch (err) {
    console.error("Command registration failed:");
    console.error(err);
  }
})();
