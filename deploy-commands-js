require('dotenv').config();
const { REST, Routes, SlashCommandBuilder } = require('discord.js');

const { TOKEN, CLIENT_ID } = process.env;

// ❌ For GLOBAL commands you do NOT need GUILD_ID
if (!TOKEN || !CLIENT_ID) {
  console.error("Missing TOKEN or CLIENT_ID in environment variables");
  process.exit(1);
}

const commands = [
  new SlashCommandBuilder()
    .setName('flood')
    .setDescription('Send messages with Willy')
    .addStringOption(o =>
      o.setName('message')
        .setDescription('Message to send')
        .setRequired(true)
    )
    .addIntegerOption(o =>
      o.setName('count')
        .setDescription('Number of times to send (1-16)')
        .setMinValue(1)
        .setMaxValue(16)
    ),

  new SlashCommandBuilder()
    .setName('earthrock')
    .setDescription('We Active'),

].map(cmd => cmd.toJSON());

const rest = new REST({ version: '10' }).setToken(TOKEN);

(async () => {
  try {
    console.log("Registering GLOBAL commands...");

    await rest.put(
      Routes.applicationCommands(CLIENT_ID),
      { body: commands }
    );

    console.log("Global commands registered successfully!");
  } catch (err) {
    console.error("Command registration failed:");
    console.error(err);
  }
})();
